# WhiteNoise Pro - 配置文件模板
# 复制为 .env 并填写实际值

# ========== 图标配置 ==========
# 图标 CDN 地址
ICON_CDN_URL=https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.4.0/svgs/solid
# 图标生成 API 密钥 (如使用 AI 生成)
ICON_GENERATE_API_KEY=your_api_key_here

# ========== 音频配置 ==========
# 音频库 URL
AUDIO_LIBRARY_URL=https://freesound.org/api/v2
# 音频 API 密钥
AUDIO_API_KEY=your_api_key_here
# 下载超时 (秒)
AUDIO_DOWNLOAD_TIMEOUT=900
# 音频格式转换工具路径
FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe

# ========== 部署配置 ==========
# GitHub Token (用于推送)
GITHUB_TOKEN=your_github_token
# Vercel Token (如使用 Vercel)
VERCEL_TOKEN=your_vercel_token
# Netlify Token (如使用 Netlify)
NETLIFY_TOKEN=your_netlify_token
# 部署目标平台 (github, vercel, netlify)
DEPLOY_TARGET=github
# 项目根目录
PROJECT_ROOT=D:\cowapout\WhiteNoise-Pro

# ========== 通知配置 ==========
# 飞书 Webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_key
# 是否启用通知 (true/false)
ENABLE_NOTIFICATION=true

# ========== 日志配置 ==========
# 日志目录
LOG_DIR=D:\cowapout\WhiteNoise-Pro\logs
# 日志保留天数
LOG_RETENTION_DAYS=30
